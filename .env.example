# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# LLM Provider (optional — falls back to template-based reports)
GROQ_API_KEY=your_groq_api_key_here

# Database (defaults to SQLite for local development)
DATABASE_URL=sqlite:///data/crypto_intel.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/crypto_intel

# Redis (optional — used for price caching)
# REDIS_URL=redis://localhost:6379/0

# CoinGecko API (free tier, no key required)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Logging
LOG_LEVEL=INFO

# Alert monitoring interval (seconds)
ALERT_CHECK_INTERVAL_SECONDS=60

# News refresh interval (seconds)
NEWS_REFRESH_INTERVAL_SECONDS=300
